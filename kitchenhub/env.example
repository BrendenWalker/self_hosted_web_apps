# Database Configuration
# PostgreSQL connection settings
DB_HOST=postgres
DB_PORT=5432
DB_NAME=kitchenhub
DB_USER=postgres
DB_PASSWORD=your_password_here

# Backend Configuration
# Docker Compose sets PORT=80 in the container (host maps 8080:80).
# Local `npm run dev` in kitchenhub/backend defaults to 8080 so it matches the Vite proxy.
PORT=80

# Note: Copy this file to .env and update with your actual values
# The .env file is gitignored and should not be committed to version control
