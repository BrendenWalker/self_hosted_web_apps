# Copy to .env next to docker-compose.yml (gitignored).

# Image tag for local builds
NEXTCLOUD_IMAGE_NAME=nextcloud:33-apache-smb

# HTTP port on the host (default avoids clashing with VehicleHub 8090/8091)
NEXTCLOUD_HTTP_PORT=8120

# Host paths for bind mounts (create directories or adjust paths)
NEXTCLOUD_HTML_HOST_PATH=./volumes/html
NEXTCLOUD_DATA_HOST_PATH=./volumes/data
NEXTCLOUD_CONFIG_HOST_PATH=./volumes/config
REDIS_DATA_HOST_PATH=./volumes/redis

# PostgreSQL (use your existing server or container hostname reachable from this stack)
POSTGRES_HOST=postgres.example.org
POSTGRES_DB=nextcloud
POSTGRES_USER=nextcloud
POSTGRES_PASSWORD=change_me

# Space-separated hostnames Nextcloud should accept
NEXTCLOUD_TRUSTED_DOMAINS=localhost nextcloud.example.org

NEXTCLOUD_DATA_DIR=/var/www/html/data
PHP_MEMORY_LIMIT=1024M

# nextcloud-cron uses image /cron.sh (runs cron.php as www-data every 5 minutes). Do not run cron.php as root.
