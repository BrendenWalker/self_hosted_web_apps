# Copy to pethub/.env and adjust values.

# PostgreSQL (same pattern as other hubs; DATABASE_URL overrides these if set)
DB_HOST=postgres
DB_PORT=5432
DB_NAME=pethub
DB_USER=postgres
DB_PASSWORD=your_password_here

# Flask
SECRET_KEY=change-me-to-a-long-random-string

# Weekly email summary (optional)
SMTP_HOST=
SMTP_PORT=25
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=
EMAIL_TO=
SUMMARY_DAY=sunday
SUMMARY_HOUR=18
SUMMARY_TZ=America/Los_Angeles

# CORS (Flask): comma-separated origins for /api/* when using a separate dev origin (e.g. Vite on 3002)
CORS_ORIGINS=http://localhost:3002

# Features
ALLOW_SIGNUP=1
SCHED_PRIMARY=1
ENABLE_SCHEDULER=1
ENABLE_AUTO_SCHEMA_SYNC=1
