# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=retirementhub
DB_USER=postgres
DB_PASSWORD=your_password_here

# Backend port (default 80 in container; mapped to 8100 in docker-compose)
PORT=80

# Optional: set to allow 0% portfolio growth and 0% expense COLA on Projections (for testing).
# Backend: DEBUG=1 (or any non-empty value). Frontend: VITE_DEBUG=1 in frontend/.env or when running vite.
# DEBUG=
