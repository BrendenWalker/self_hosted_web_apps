# Mailhub Portainer stack – copy to .env and set values.
# Host paths: all container config/data under /home/<container_name>; bind from host for backup/edit.

# Registry and images
DOCKER_HUB_REGISTRY_USERNAME=your-dockerhub-username
DOCKER_HUB_POSTFIX_IMAGE_NAME=mailhub-postfix
DOCKER_HUB_AMAVISD_IMAGE_NAME=mailhub-amavisd
DOCKER_HUB_DOVECOT_IMAGE_NAME=mailhub-dovecot
IMAGE_TAG=latest

# Host directory for bind mounts (e.g. /host/data/mailhub or ./mailhub-data)
MAILHUB_DATA_ROOT=./mailhub-data

# Postfix
MYHOSTNAME=mail.example.com
# Must be the exact domain you receive mail at (e.g. muletrain.example.com). Postfix adds this to mydestination
# so mail to user@ that domain (including quarantine addresses) is delivered locally via Dovecot. Amavisd also
# uses this when AMAVISD_LOCAL_DOMAINS is unset so recipients are "local" and spam is quarantined.
MYDOMAIN=example.com
RELAYHOST=smarthost.example.com:26
# Optional: SASL for relay (create sasl_passwd in mailhub-postfix data dir and run postmap)

# Ports (host:container)
SMTP_PORT=25
SMTPS_PORT=465
IMAPS_PORT=993
IMAP_PORT=143
MANAGESIEVE_PORT=4190
POP3S_PORT=995

# Fetchmail poll interval (seconds)
FETCHMAIL_POLL=60
# Optional: set to 1 to log fetchmail connection/auth to container stdout (docker logs mailhub-postfix)
# FETCHMAIL_VERBOSE=1

# Amavisd FQDN for $myhostname (default mailhub-amavisd.local)
AMAVISD_MYHOSTNAME=mailhub-amavisd.local
# REQUIRED for quarantine: domain(s) of your local recipients so amavisd does not treat them as outbound.
# If unset or wrong, spam/virus show DiscardedOutbound and never reach quarantine. Use the parent domain
# so all subdomains match (e.g. plud.org for user@muletrain.plud.org). Space- or comma-separated.
# In Portainer: add this under the stack's "Environment variables" so the container receives it.
# AMAVISD_LOCAL_DOMAINS=plud.org
# Optional: IPs/CIDRs allowed to connect to amavisd (space-separated). Default: 127.0.0.1 [::1] 172.16.0.0/12
# Use quotes if value contains spaces: AMAVISD_INET_ACL="127.0.0.1 [::1] 172.18.0.0/16"
# AMAVISD_INET_ACL=

# Amavisd quarantine recipients (optional; leave blank to disable)
AMAVISD_SPAM_QUARANTINE_TO=spam-quarantine@example.com
AMAVISD_VIRUS_QUARANTINE_TO=virus-quarantine@example.com
# Spam kill level when spam quarantine is enabled (default 5.0). Mail at/above this score is blocked and quarantined.
# AMAVISD_SPAM_KILL_LEVEL=5.0
# Spam subject tag: prefix added to Subject for mail at/above tag level (default ***SPAM*** from image).
# AMAVISD_SPAM_SUBJECT_TAG=***SPAM***
# Score above which Subject gets the spam tag (default -999 = tag all that amavisd marks). Use e.g. 2.0 to only tag when score >= 2.
# AMAVISD_SPAM_TAG_LEVEL=-999
# Score above which X-Spam-Flag etc. are added (optional; amavisd default if unset).
# AMAVISD_SPAM_TAG2_LEVEL=4.0

# Dovecot LMTP port inside container (default 24)
DOVECOT_LMTP_PORT=24

# Sa-learn from user maildirs (optional). When set, amavisd runs sa-learn daily at 03:00 on
# messages in per-user folders, then deletes those messages. Path = directory containing one
# subdir per user (each subdir is a maildir root). The script looks for:
#   - .Admin.Spam.Ham + .Admin.Spam.DefinateSpam → learn ham/spam, then clean both
#   - .spam → learn spam, then clean
# With the stack's dovecot volume mounted in amavisd, use the path inside the container:
# SALEARN_USER_MAILDIRS=/home/mailhub-dovecot/maildir
# Leave empty to disable. Optional: SALEARN_SA_USER (default amavis).
# SALEARN_USER_MAILDIRS=/home/mailhub-dovecot/maildir
# SALEARN_SA_USER=amavis
