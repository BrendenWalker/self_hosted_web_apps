# Optional: copy to stack.env so these env vars reach amavisd even when the stack/orchestrator does not pass them into the container (e.g. Portainer).
# The entrypoint reads this file line-by-line and exports each VAR=value (no shell expansion), so * and spaces in values are safe.
# Uncomment and set as needed. One VAR=value per line; lines starting with # are ignored.

# AMAVISD_LOCAL_DOMAINS=example.com
# MYDOMAIN=example.com
# AMAVISD_SPAM_QUARANTINE_TO=spam-quarantine@example.com
# AMAVISD_VIRUS_QUARANTINE_TO=virus-quarantine@example.com
# AMAVISD_SPAM_SUBJECT_TAG=** SPAM **
# AMAVISD_SPAM_TAG2_LEVEL=4.0
# Sa-learn from user maildirs (path inside container, e.g. when dovecot is mounted as /home/mailhub-dovecot):
# SALEARN_USER_MAILDIRS=/home/mailhub-dovecot/maildir
