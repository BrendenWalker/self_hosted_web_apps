# Optional: copy to stack.env so these env vars reach amavisd even when the stack/orchestrator does not pass them into the container (e.g. Portainer).
# The entrypoint sources stack.env at startup; supervisord and amavisd inherit the environment.
# Uncomment and set as needed. One VAR=value per line; no export needed.

# AMAVISD_LOCAL_DOMAINS=plud.org
# MYDOMAIN=plud.org
# AMAVISD_SPAM_QUARANTINE_TO=spam@muletrain.plud.org
# AMAVISD_VIRUS_QUARANTINE_TO=virus@muletrain.plud.org
# AMAVISD_SPAM_SUBJECT_TAG=** SPAM **
# AMAVISD_SPAM_TAG2_LEVEL=4.0
